# ==========================================
# 環境変数設定例
# ==========================================
# このファイルを .env.local にコピーして使用してください
# cp env.example .env.local

# ==========================================
# Supabase 設定
# ==========================================
# Supabaseを使用する場合は以下を設定
# https://app.supabase.com/ から取得

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==========================================
# Stripe 設定
# ==========================================
# https://dashboard.stripe.com/apikeys から取得

# Stripe APIキー
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# お試しプラン（6食セット - 一回購入）のPrice ID
STRIPE_PRICE_TRIAL_6SET_TEST=price_xxx
STRIPE_PRICE_TRIAL_6SET_LIVE=price_xxx

# サブスクリプション月額プランのPrice ID（旧価格体系・非推奨）
# 12食プラン（月1回配送）¥8,780/月（商品¥7,280 + 送料¥1,500）
STRIPE_SUBSCRIPTION_PRICE_12_MONTHLY_TEST=price_xxx
STRIPE_SUBSCRIPTION_PRICE_12_MONTHLY_LIVE=price_xxx

# 24食プラン（月2回配送）¥17,600/月（商品¥14,600 + 送料¥3,000）
STRIPE_SUBSCRIPTION_PRICE_24_MONTHLY_TEST=price_xxx
STRIPE_SUBSCRIPTION_PRICE_24_MONTHLY_LIVE=price_xxx

# 48食プラン（月4回配送）¥33,800/月（商品¥27,800 + 送料¥6,000）
STRIPE_SUBSCRIPTION_PRICE_48_MONTHLY_TEST=price_xxx
STRIPE_SUBSCRIPTION_PRICE_48_MONTHLY_LIVE=price_xxx

# ----------------------------------------------------------
# サブスクリプション Phase1（初回送料無料特価）
# アンカー価格: 6食=¥9,000 / 12食=¥18,000 / 24食=¥36,000
# Phase1商品価格: 6食=¥4,980 / 12食=¥12,600 / 24食=¥25,200
STRIPE_SUBSCRIPTION_PRICE_12_PHASE1=price_xxx
STRIPE_SUBSCRIPTION_PRICE_24_PHASE1=price_xxx
STRIPE_SUBSCRIPTION_PRICE_48_PHASE1=price_xxx

# サブスクリプション Phase2（2ヶ月目〜15%OFF）
# Phase2商品価格: 6食=¥7,650 / 12食=¥15,300 / 24食=¥30,600
STRIPE_SUBSCRIPTION_PRICE_12_PHASE2=price_xxx
STRIPE_SUBSCRIPTION_PRICE_24_PHASE2=price_xxx
STRIPE_SUBSCRIPTION_PRICE_48_PHASE2=price_xxx

# 初回送料無料用（¥0 recurring price）
# Stripeで新規作成: 月次請求・金額¥0 のrecurring price
STRIPE_SHIPPING_PRICE_FREE=price_xxx

# Phase2 有料送料（¥1,500 recurring price・webhookで使用）
STRIPE_SHIPPING_PRICE_12=price_xxx

# お試しプラン送料（¥1,500 one-time price・checkoutで使用）
STRIPE_SHIPPING_PRICE_TRIAL=price_xxx

# お試しプラン商品（checkoutで使用する実際の変数名）
STRIPE_PRICE_TRIAL_6SET=price_xxx

# ==========================================
# 認証設定
# ==========================================
# JWT シークレット（ランダムな文字列を生成）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# 管理者ユーザー名
ADMIN_USERNAME=admin

# 管理者パスワードのハッシュ値
# デフォルトパスワード: admin123
# 新しいパスワードのハッシュ生成方法:
# node -e "require('bcryptjs').hash('your-password', 10, (e,h) => console.log(h))"
ADMIN_PASSWORD_HASH=$2b$10$SZmfJkOUTYKq..1dqWHtDOpe6HaV1ycuwsccq.KB1OhTu1bm4IlVS

# ==========================================
# 開発環境のみ（オプション）
# ==========================================
# 開発中に認証を無効化したい場合のみ設定
# 本番環境では絶対に設定しないでください！
ENABLE_AUTH=false

# ==========================================
# メール送信設定（Resend）
# ==========================================
# Resend API Key
# https://resend.com/api-keys から取得
RESEND_API_KEY=re_xxxxx...
RESEND_FROM_EMAIL=ふとるめし <noreply@futorumeshi.com>
FROM_EMAIL=ふとるめし <noreply@futorumeshi.com>

# ==========================================
# Slack 通知設定
# ==========================================
# Slack Webhook URL
# https://api.slack.com/messaging/webhooks から取得
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ==========================================
# 日次注文レポート設定
# ==========================================
# 業者へのメール送信先アドレス（カンマ区切りで複数指定可能）
# 例: VENDOR_EMAIL=sales@landbridge.co.jp,info@landbridge.co.jp,takeuchi@landbridge.co.jp
# 未設定の場合は、takeuchi@landbridge.co.jp に送信されます
VENDOR_EMAIL=vendor@example.com

# Cronジョブの認証用シークレット（ランダムな文字列を生成）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Vercel Cron Jobsから呼び出される際の認証に使用
CRON_SECRET=your-cron-secret-key-change-in-production

# ==========================================
# サイト設定
# ==========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# Google Analytics 4 設定
# ==========================================
# GA4 測定ID（サイトトラッキング用）- クライアントサイドで使用
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 プロパティID（API用）- 数字のみ
GA_PROPERTY_ID=123456789

# サービスアカウント認証情報（API用）
# Google Cloud Console からダウンロードしたJSONファイルの値
GA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ==========================================
# Google Search Console 設定
# ==========================================
# Search Consoleに登録したサイトURL
SEARCH_CONSOLE_SITE_URL=https://www.example.com/

# ==========================================
# Microsoft Clarity 設定
# ==========================================
# ClarityプロジェクトID（サイトトラッキング用）
NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# ==========================================
# Node 環境
# ==========================================
NODE_ENV=development
