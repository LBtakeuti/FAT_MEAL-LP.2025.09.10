# ── サイト設定 ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# お試しプラン（買い切り・trial-6）
STRIPE_PRICE_TRIAL_6SET=
STRIPE_SHIPPING_PRICE_TRIAL=

# サブスクリプション（月額・新3プラン体系・段階割引なし）
# 商品/送料は recurring monthly Price として発行する
STRIPE_PRICE_SUB6_PRODUCT=    # 6食プラン 商品 ¥3,000/月
STRIPE_PRICE_SUB12_PRODUCT=   # 12食プラン 商品 ¥6,000/月
STRIPE_PRICE_SUB_SHIPPING=    # サブスク送料 ¥1,500/月（共通）

# DEPRECATED ── Legacy 用（既存 subscription-monthly-12 契約者の Stripe Subscription
# Schedule が現在も参照中のため残置。新規購入では使わない）
STRIPE_SUBSCRIPTION_PRICE_12_PHASE1=
STRIPE_SUBSCRIPTION_PRICE_12_PHASE2=
STRIPE_SHIPPING_PRICE_FREE=
STRIPE_SHIPPING_PRICE=

# ── 通知・メール ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
VENDOR_EMAIL=
MAIL_ALERT_TO=
MAIL_CONTACT_EMAIL=

# ── Cron ─────────────────────────────────────────────────────
CRON_SECRET=

# ── アナリティクス ────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA_PROPERTY_ID=
GA_CLIENT_EMAIL=
GA_PRIVATE_KEY=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_GTM_ID=
SEARCH_CONSOLE_SITE_URL=

# ── 配送元情報（CSV出力・メール用） ──────────────────────────
SENDER_PHONE=
SENDER_POSTAL_CODE=
SENDER_ADDRESS=
SENDER_COMPANY=
